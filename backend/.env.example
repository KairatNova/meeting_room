# Скопируйте в .env и заполните значения.
# База данных PostgreSQL
#DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_rooms

# Секрет для JWT (обязательно сменить в продакшене)
#SECRET_KEY=your-secret-key-min-32-chars

# Режим отладки (SQL в консоль и т.д.)
#DEBUG=false

# CORS: через запятую, без пробелов
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Для production (Railway frontend URL):
# CORS_ORIGINS=https://your-frontend.up.railway.app

# SMTP для отправки кода подтверждения email (если пусто — код выводится в консоль)
# Gmail: включите "Ненадёжные приложения" или используйте пароль приложения
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_TIMEOUT_SECONDS=20
# EMAIL_FAIL_OPEN=true
# Время жизни кода (минуты)
# EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=10

# Telegram-бот для кодов верификации и сброса пароля (опционально)
# Создайте бота через @BotFather, укажите токен и username без @
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_BOT_USERNAME=YourMeetingBot
#
# После деплоя зарегистрируйте webhook (иначе бот не получит Start и не пришлёт код):
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://ВАШ_ДОМЕН/api/telegram/webhook"
